PORT=4000
DB_PORT=3309
DB_HOST=localhost
DB_USER=root
DB_PASS=1234
DB_NAME=global_gate

# 100ms / HMS credentials (required for live sessions)
# Guidance for values you can copy from your 100ms dashboard:
# - App Access Key: client-side key (DO NOT use here)
# - App Secret (a.k.a. Server API Key): SERVER secret — use this for HMS_API_KEY
# - Management Token: an alternate server token; you may use this instead of App Secret
# - Project ID: the 100ms Project identifier — use this for HMS_PROJECT_ID
#
# Set `HMS_API_KEY` to your App Secret (Server API Key) OR the Management Token.
# Keep this value secret and never commit it to source control.
# Example:
HMS_API_KEY=694bbad763cbbe924eef81e3
# Set `HMS_PROJECT_ID` to your 100ms Project ID (copy from Project settings)
HMS_PROJECT_ID=694c038e033903926e635a81

# Email Configuration - REQUIRED for Forgot Password Feature
# For Gmail: Generate App Password from https://myaccount.google.com/apppasswords
# 1. Enable 2FA on Gmail
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password and paste below as EMAIL_PASS

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL - Used in password reset email links
FRONTEND_URL=http://localhost:5173

# Admin Credentials (Legacy/Fallback)
ADMIN_USER=admin@globalgate
ADMIN_PASS=admin123

# Notes:
# - Copy this file to .env in the backend folder and fill the values.
# - Restart the backend after updating .env (see restart_backend.ps1 or run `node index.js`).
# - If you don't have 100ms configured for local testing, set DEV_HMS_MOCK=true
#   to return a placeholder token and use the frontend mock session UI.
DEV_HMS_MOCK=false
